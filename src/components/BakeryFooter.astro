---
const currentYear = new Date().getFullYear();
---

<footer id="footer" class="simple-footer">
  <div class="wrap">
    <div class="footer-top">
      <div class="brand-social">
        <div class="footer-logo">
          <img
            src="/ejemplo-villa-eucalipto-y-romero-glamping/images/logo.png"
            alt="danny tortas"
          />
        </div>
        <div class="social-links">
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/danystortas/"
            target="_blank"
            rel="noopener"
            aria-label="Instagram"
            class="social-icon"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <circle
                cx="17.5"
                cy="6.5"
                r="1.2"
                fill="currentColor"
                stroke="none"></circle>
            </svg>
          </a>
          <!-- Facebook -->
          <a
            href="https://www.facebook.com/panaderiadanny tortas"
            target="_blank"
            rel="noopener"
            aria-label="Facebook"
            class="social-icon"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
              ></path>
            </svg>
          </a>
          <!-- TikTok -->
          <a
            href="https://www.tiktok.com/@panaderia.danny tortas"
            target="_blank"
            rel="noopener"
            aria-label="TikTok"
            class="social-icon"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.79a8.18 8.18 0 0 0 4.79 1.53V6.88a4.85 4.85 0 0 1-1.02-.19z"
              ></path>
            </svg>
          </a>
          <!-- X (Twitter) -->
          <a
            href="#"
            target="_blank"
            rel="noopener"
            aria-label="X"
            class="social-icon"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
      <a
        href="/ejemplo-villa-eucalipto-y-romero-glamping/pedido"
        class="footer-pide-btn-final">Pide en línea</a
      >
    </div>

    <hr class="footer-divider" />

    <div class="footer-bottom">
      <p>
        Copyright © {currentYear} Panaderías danny tortas. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>

<style>
  .simple-footer {
    background: var(--color-brown-dark);
    color: var(--color-cream);
    padding: 60px 0 40px;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    flex-wrap: wrap;
    gap: 20px;
  }

  .brand-social {
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .footer-logo img {
    height: 50px;
  }

  .social-links {
    display: flex;
    gap: 12px;
  }

  .social-icon {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-gold-light);
    font-weight: 600;
    font-size: 0.85rem;
    padding: 10px 16px;
    border: 1px solid rgba(240, 201, 136, 0.25);
    border-radius: 12px;
    transition: all 0.3s ease;
    text-decoration: none;
    white-space: nowrap;
  }

  .social-icon:hover {
    background: rgba(240, 201, 136, 0.12);
    border-color: var(--color-gold-light);
    transform: translateY(-3px);
    color: white;
  }

  .social-icon svg {
    flex-shrink: 0;
  }

  /* VINOTINTO button */
  .footer-pide-btn-final {
    display: inline-block;
    background: #5a1111 !important;
    color: var(--color-cream) !important;
    padding: 14px 36px;
    border-radius: 999px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 2px solid rgba(255, 255, 255, 0.15);
  }

  .footer-pide-btn-final:hover {
    background: #7a1a1a !important;
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(90, 17, 17, 0.5);
  }

  .footer-divider {
    border: 0;
    height: 1px;
    background: rgba(251, 241, 225, 0.1);
    margin-bottom: 30px;
  }

  .footer-bottom {
    text-align: center;
    font-size: 0.85rem;
    color: rgba(205, 183, 158, 0.5);
  }

  @media (max-width: 768px) {
    .footer-top {
      flex-direction: column;
      text-align: center;
    }
    .brand-social {
      flex-direction: column;
      gap: 20px;
    }
    .social-links {
      flex-wrap: wrap;
      justify-content: center;
    }
    .social-icon span {
      display: none;
    }
    .social-icon {
      padding: 10px 12px;
    }
  }
</style>
